{
  "name": "justsolve/laravel-pec",
  "description": "Manage PEC emails with Laravel.",
  "type": "library",
  "authors": [
        {
            "name": "Iorio Francesco",
            "email": "francesco.iorio@just-solve.com"
        }
    ],
  "require": {
    "php": "^8.2",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "JustSolve\\LegalmailPec\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "JustSolve\\LegalmailPec\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "JustSolve\\LegalmailPec\\PecServiceProvider"
      ],
      "aliases": {
        "Pec": "JustSolve\\LegalmailPec\\Facades\\Pec"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "orchestra/testbench": "^10.9"
  }
}
